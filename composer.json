{
    "name": "apitube/news-api",
    "description": "PHP SDK for the APITube News API",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "news",
        "news-api",
        "api-client",
        "php-sdk",
        "headlines",
        "sentiment-analysis",
        "nlp",
        "rest-api",
        "apitube",
        "news-aggregator",
        "psr-18"
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.1",
        "php-http/discovery": "^1.20",
        "psr/http-client": "^1.0",
        "psr/http-client-implementation": "*",
        "psr/http-factory": "^1.0",
        "psr/http-factory-implementation": "*"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.9",
        "php-http/mock-client": "^1.6",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "APITube\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "APITube\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
